generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id Int @id @default(autoincrement())
  email String @unique
  password String 
  name String?
  createRoom CreateRoom[]
}

model CreateRoom {
  id Int @unique @default(autoincrement())
  name String 
  roomId Int
  room User @relation(fields: [roomId],references: [id])
}